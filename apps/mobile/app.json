{
  "expo": {
    "name": "Remi",
    "slug": "remi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.remi.app",
      "newArchEnabled": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Remi needs microphone access to let you speak your thoughts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.remi.app",
      "newArchEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "remi"
  }
}